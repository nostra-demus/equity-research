data
.cache
.DS_Store
**/.DS_Store

# Local module-audit scratch — single-file consolidated views used to edit the
# agent prompts; canonical content is tracked under .claude/agents/. Kept on
# disk, out of version control.
/*_audit.md
/*_audit.txt
/*_audit.pdf

# python tool venvs (recreate via .claude/tools/setup-tools.sh)
.venv/

# generated cockpit snapshot — rebuilt by `npm run build` (build-snapshot.mjs); never commit build output (footgun fix)
ui/web/public/data/

# regenerable pool extracts (rebuilt by extract_pool.py) — never commit
_pool_extracts/
**/_pool_extracts/

# python bytecode cache
__pycache__/
*.pyc

# Cloudflare wrangler local cache (account info / build cache) — never commit
.wrangler/
