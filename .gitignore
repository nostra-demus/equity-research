data
.cache
.DS_Store
**/.DS_Store

# Engine secrets (§28) — GitHub App identity AND LLM provider API keys. The real ones live in
# ~/.config/nostra-engine (outside the repo, loaded by src/load-env.ts); these are guards so a stray
# copy of a private key, the App env, or a provider-keys file can never be committed by accident.
*.pem
github-app.env
providers.env
.token-cache
nostra-engine/

# Local module-audit scratch — single-file consolidated views used to edit the
# agent prompts; canonical content is tracked under .claude/agents/. Kept on
# disk, out of version control.
/*_audit.md
/*_audit.txt
/*_audit.pdf

# python tool venvs (recreate via .claude/tools/setup-tools.sh)
.venv/

# generated cockpit snapshot — rebuilt by `npm run build` (build-snapshot.mjs); never commit build output (footgun fix)
ui/web/public/data/

# Playwright test-run artifacts (traces/screenshots on failure, HTML report) — regenerated on every run
ui/web/test-results/
ui/web/playwright-report/

# regenerable pool extracts (rebuilt by extract_pool.py) — never commit
_pool_extracts/
**/_pool_extracts/

# transient defer-module-memos marker (written by the per-module chain, removed at run end / on failure) — never commit
**/.defer_module_memos

# python bytecode cache
__pycache__/
*.pyc

# Cloudflare wrangler local cache (account info / build cache) — never commit
.wrangler/
