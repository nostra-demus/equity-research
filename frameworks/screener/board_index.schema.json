{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "frameworks/screener/board_index.schema.json",
  "title": "Screener board index",
  "description": "The single canonical machine-readable state of the screener pipeline board, at screener/board/index.json. Rebuilt deterministically by scripts/update_board_index.py from the ledger + run folders + inbox. The cockpit board reads THIS file (plus live in-memory runs) — it never crawls agent prose.",
  "type": "object",
  "required": ["generated_at", "inbox", "signals", "theses", "handoffs", "counts"],
  "properties": {
    "generated_at": { "type": "string" },
    "inbox": {
      "type": "array",
      "description": "Unconsumed sweep rows (newest first).",
      "items": {
        "type": "object",
        "required": ["inbox_id", "headline", "source_name", "found_at"],
        "properties": {
          "inbox_id": { "type": "string" },
          "headline": { "type": "string" },
          "url": { "type": "string" },
          "source_name": { "type": "string" },
          "input_nature": { "type": "string" },
          "found_at": { "type": "string" },
          "sweep_file": { "type": "string" },
          "prelim_note": { "type": "string" },
          "dedup_status": { "type": "string", "enum": ["new", "possible_duplicate"] },
          "consumed": { "type": "boolean" },
          "launched_signal_id": { "type": ["string", "null"] },
          "triage_score": { "type": ["integer", "null"], "description": "Composite PRIORITY 0–100 (absent on manual-sweep rows): the cheap Groq materiality read, re-ranked deterministically by §4 source tier (filing>news), company-vs-broad scope, strongest event, size and recency (news/rank.ts). Orders + bands the inbox. NOT the authoritative gauntlet score." },
          "triage_reason": { "type": "string" },
          "region": { "type": "string", "description": "US / IN / GLOBAL / OTHER" },
          "relevance": { "type": "string" },
          "materiality_pre_score": { "type": ["integer", "null"], "description": "The RAW Groq title-only materiality read, before the composite re-rank — kept for transparency." },
          "rank_factors": { "type": ["object", "null"], "description": "Breakdown of the composite triage_score: { materiality, source_tier, scope, event, size, recency, scope_id, source_tier_id } (news/rank.ts)." },
          "event_types": { "type": "array", "items": { "type": "string" }, "description": "Theme tags from the gauntlet's event-type vocabulary (mna, regulatory, …)." },
          "issuer_linkage": { "type": "string", "description": "primary / secondary / sector / macro." },
          "companies": {
            "type": "array",
            "description": "Companies the cheap scanner GUESSED from the headline alone — never verified extraction.",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "ticker": { "type": ["string", "null"] },
                "listing_country": { "type": ["string", "null"] }
              }
            }
          },
          "size_bucket": { "type": "string", "description": "Guessed size of the main company: mega / large / mid / small / unknown (or empty on manual rows)." },
          "dismissed": { "type": "boolean", "description": "Human state: hidden from the Inbox lane via the cockpit; restorable." },
          "dismissed_at": { "type": "string" },
          "dismissed_by": { "type": "string" }
        }
      }
    },
    "signals": {
      "type": "array",
      "description": "Every processed signal (from the events ledger), newest first.",
      "items": {
        "type": "object",
        "required": ["signal_id", "headline", "status"],
        "properties": {
          "signal_id": { "type": "string" },
          "event_id": { "type": "string" },
          "headline": { "type": "string" },
          "source_name": { "type": "string" },
          "source_grade": { "type": "string" },
          "processed_at": { "type": "string" },
          "run_root": { "type": "string" },
          "materiality_score": { "type": ["integer", "null"] },
          "novelty_score": { "type": ["number", "null"] },
          "pair_label": { "type": ["string", "null"] },
          "action": { "type": ["string", "null"] },
          "status": { "type": "string", "description": "PROMOTE / PARK / LOG / suppress / watchlist_no_source / in_gauntlet / thesis statuses once Phase 1 ran." },
          "status_reason": { "type": "string" },
          "thesis_id": { "type": ["string", "null"] }
        }
      }
    },
    "theses": {
      "type": "array",
      "description": "Every thesis record (from screener/ledger/theses/), newest first.",
      "items": {
        "type": "object",
        "required": ["thesis_id", "signal_id", "status"],
        "properties": {
          "thesis_id": { "type": "string" },
          "signal_id": { "type": "string" },
          "headline": { "type": "string" },
          "status": { "type": "string" },
          "status_reason": { "type": "string" },
          "routing_reason": { "type": "string" },
          "next_action": { "type": "string" },
          "edge_score": { "type": ["integer", "null"] },
          "horizon": { "type": ["string", "null"] },
          "falsification_sentence": { "type": ["string", "null"] },
          "convergence_trigger": { "type": ["string", "null"] },
          "trigger_date_range": { "type": ["string", "null"] },
          "locked": { "type": "boolean" },
          "run_root": { "type": "string" },
          "effective_status": { "type": "string", "description": "Where the board shows this thesis: the engine's status unless a human moved it (overrides.ndjson, latest wins). The engine's own `status` is never altered." },
          "override": {
            "type": ["object", "null"],
            "description": "The active human move, when one exists.",
            "properties": {
              "from_status": { "type": "string", "description": "The engine status at move time — staleness detection anchor." },
              "to_status": { "type": "string" },
              "reason": { "type": "string" },
              "moved_by": { "type": "string" },
              "moved_at": { "type": "string" }
            }
          },
          "override_stale": { "type": "boolean", "description": "True when the engine re-ran and changed its status AFTER the human move — surfaced in the UI, never silently resolved." },
          "candidate_count": { "type": "integer" },
          "candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "candidate_id": { "type": "string" },
                "ticker": { "type": "string" },
                "company_name": { "type": "string" },
                "side": { "type": "string" },
                "exposure_score": { "type": "integer" },
                "handed_off": { "type": "boolean" }
              }
            }
          },
          "conviction": {
            "type": ["object", "null"],
            "description": "Phase 3 live-book snapshot (engine-owned, separate from the human override). Full shape: frameworks/screener/conviction.schema.json. Null when the conviction loop has not seeded this thesis.",
            "properties": {
              "state": { "type": "string", "enum": ["watching", "provisional", "strong", "confirmed", "fading", "handed_off", "falsified_discarded", "expired_unproven"] },
              "sell_side_rating": { "type": "string" },
              "edge_locked": { "type": "integer" },
              "edge_score_live": { "type": "integer" },
              "conviction": { "type": "integer" },
              "upgrade_velocity": { "type": "number", "description": "Edge points / 30 days (signed) — the 'rate of upgrade'." },
              "trajectory_enum": { "type": "string", "enum": ["accelerating", "steady", "stalling", "decaying"] },
              "rank_score": { "type": "number" },
              "proximity_pct": { "type": "number" },
              "progress_confirmed": { "type": "integer" },
              "progress_total": { "type": "integer" },
              "validated": { "type": "boolean" },
              "trajectory": { "type": "array", "items": { "type": "object" } },
              "next_checkpoint": { "type": ["object", "null"] },
              "stale": { "type": "boolean" },
              "insufficient": { "type": "boolean" },
              "archived": { "type": "boolean" },
              "plain_note": { "type": "string" }
            }
          }
        }
      }
    },
    "handoffs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["handoff_id", "thesis_id", "ticker", "handed_off_at", "seeded_path"],
        "properties": {
          "handoff_id": { "type": "string" },
          "thesis_id": { "type": "string" },
          "ticker": { "type": "string" },
          "handed_off_at": { "type": "string" },
          "seeded_path": { "type": "string" },
          "research_run_root": { "type": ["string", "null"] }
        }
      }
    },
    "counts": {
      "type": "object",
      "description": "Funnel totals for the board header.",
      "properties": {
        "inbox_unconsumed": { "type": "integer" },
        "signals_total": { "type": "integer" },
        "parked": { "type": "integer" },
        "logged": { "type": "integer" },
        "watchlist": { "type": "integer" },
        "provisional": { "type": "integer" },
        "full_machine": { "type": "integer" },
        "handed_off": { "type": "integer" },
        "news_seen_today": { "type": "integer", "description": "Autonomous ingester: on-list items triaged today." },
        "news_picked_today": { "type": "integer", "description": "Autonomous ingester: items scored worth inboxing today." },
        "news_dropped_today": { "type": "integer", "description": "Autonomous ingester: items triaged but not inboxed today." }
      }
    },
    "book_momentum": {
      "type": "object",
      "description": "Phase 3 live book: is the desk's set of live ideas upgrading on balance? The headline 'upgrading at +N/30d' number.",
      "properties": {
        "live_count": { "type": "integer" },
        "upgrading_count": { "type": "integer" },
        "decaying_count": { "type": "integer" },
        "mean_upgrade_velocity": { "type": "number", "description": "Mean edge-points / 30 days across live theses." },
        "confirmed_count": { "type": "integer" },
        "fading_count": { "type": "integer" },
        "stale_count": { "type": "integer" },
        "archived_count": { "type": "integer" }
      }
    }
  }
}
