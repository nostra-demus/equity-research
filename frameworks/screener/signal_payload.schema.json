{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "frameworks/screener/signal_payload.schema.json",
  "title": "Phase 0.1 signal payload",
  "description": "The structured output of the signal-gate module (the ten-step gauntlet). Written to screener/runs/<SIG_ID>/signal_payload.json by the signal-gate synthesis.",
  "type": "object",
  "required": [
    "signal_id",
    "event_id",
    "processed_at",
    "relevance_label",
    "relevance_confidence",
    "event_types",
    "issuer_linkage",
    "similarity_score",
    "pair_label",
    "fact_delta",
    "confirmation_upgrade",
    "novelty_score",
    "action",
    "materiality_score",
    "routing",
    "routing_reason",
    "sources"
  ],
  "properties": {
    "signal_id": { "type": "string", "pattern": "^SIG-[0-9]{8}-[a-f0-9]{8}$" },
    "event_id": { "type": "string", "pattern": "^EVT-[a-f0-9]{12}$", "description": "sha256 (first 12 hex) of normalized headline + source URL." },
    "processed_at": { "type": "string" },
    "gate0": {
      "type": "object",
      "required": ["approved_source_check", "source_grade"],
      "properties": {
        "approved_source_check": { "type": "boolean" },
        "source_grade": { "type": "string", "enum": ["A", "B"] },
        "source_grade_rationale": { "type": "string" },
        "dedup_url_hash": { "type": "string" }
      }
    },
    "relevance_label": { "type": "string", "enum": ["irrelevant", "relevant_non_material", "material"] },
    "relevance_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "event_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "earnings_revenue_margin",
          "guidance_change",
          "mna",
          "capital_actions",
          "debt_credit",
          "litigation_enforcement",
          "regulatory",
          "management",
          "product",
          "commercial",
          "operations",
          "cybersecurity",
          "macro_sector",
          "rumor"
        ]
      }
    },
    "entities": {
      "type": "object",
      "properties": {
        "primary_issuers": { "type": "array", "items": { "type": "string" } },
        "secondary_issuers": { "type": "array", "items": { "type": "string" } },
        "sector": { "type": "string" },
        "geography": { "type": "string" },
        "commodity": { "type": "string" }
      }
    },
    "issuer_linkage": { "type": "string", "enum": ["primary_issuer", "secondary_issuer", "sector_only", "macro_only"] },
    "similarity_score": { "type": "number", "minimum": 0, "maximum": 1, "description": "Best-match similarity vs the 48-72h ledger window (agent-native textual-overlap rubric mapped to the cosine bands)." },
    "similar_event_ids": { "type": "array", "items": { "type": "string" } },
    "pair_label": {
      "type": "string",
      "enum": ["duplicate", "same_event_no_new_info", "same_event_new_info", "related_topic", "new_event"]
    },
    "fact_delta": { "type": "number", "minimum": 0, "maximum": 1 },
    "fact_delta_fields": { "type": "array", "items": { "type": "string" }, "description": "Which extraction fields changed (guidance, deal_value, fine_amount, eps, revenue, counterparty, court, regulator)." },
    "confirmation_upgrade": { "type": "boolean" },
    "novelty_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "action": {
      "type": "string",
      "enum": ["replace_canonical", "suppress", "keep_linked_low_rank", "keep_linked", "keep_separate"]
    },
    "materiality_score": { "type": "integer", "minimum": 0, "maximum": 100, "description": "Equal to score_breakdown's clamped final_score (scripts/screener_score_breakdown.py) — kept for backward compatibility with the board index, ledger, and frontend." },
    "materiality_math": { "type": "string", "description": "The visible arithmetic: base inputs, penalties applied, overrides applied. Auto-rendered from score_breakdown by scripts/screener_score_breakdown.py." },
    "score_breakdown": {
      "type": "object",
      "description": "The named 100-point breakdown behind materiality_score. Six positive components (source_quality, event_materiality, company_relevance, specificity, estimate_impact, theme_macro) sum to a 100-pt pre-penalty subtotal; five named penalties subtract from it. Computed by scripts/screener_score_breakdown.py — never hand-edited. The block itself stays optional for backward compatibility with pre-transparency payloads, but WHEN PRESENT it must carry all six components and all five penalties — a partial block is a defect, not a valid shorthand.",
      "required": [
        "source_quality",
        "event_materiality",
        "company_relevance",
        "specificity",
        "estimate_impact",
        "theme_macro",
        "routine_filing_penalty",
        "generic_media_penalty",
        "private_unlisted_irrelevance_penalty",
        "duplicate_stale_penalty",
        "low_confidence_extraction_penalty"
      ],
      "properties": {
        "source_quality": { "$ref": "#/definitions/score_component" },
        "event_materiality": { "$ref": "#/definitions/score_component" },
        "company_relevance": { "$ref": "#/definitions/score_component" },
        "specificity": { "$ref": "#/definitions/score_component" },
        "estimate_impact": { "$ref": "#/definitions/score_component" },
        "theme_macro": { "$ref": "#/definitions/score_component" },
        "routine_filing_penalty": { "$ref": "#/definitions/score_penalty" },
        "generic_media_penalty": { "$ref": "#/definitions/score_penalty" },
        "private_unlisted_irrelevance_penalty": { "$ref": "#/definitions/score_penalty" },
        "duplicate_stale_penalty": { "$ref": "#/definitions/score_penalty" },
        "low_confidence_extraction_penalty": { "$ref": "#/definitions/score_penalty" }
      }
    },
    "final_score_reason": { "type": "string", "description": "Plain-English 1-2 sentence summary of the final score (CLAUDE.md S21) — agent-authored, citing the largest positive driver and the largest penalty (if any)." },
    "source_tier": { "type": "integer", "minimum": 1, "maximum": 4, "description": "Refines Gate 0's A/B source_grade into 1-4 (Reuters/Bloomberg/filing class down to unknown/low-quality). Equal to score_breakdown.source_quality's basis; written by scripts/screener_score_breakdown.py." },
    "source_quality_score": { "type": "integer", "minimum": 0, "maximum": 20, "description": "Equal to score_breakdown.source_quality.value — written once, never recomputed separately." },
    "source_quality_reason": { "type": "string" },
    "issuer_public_status": { "type": "string", "enum": ["public", "private_unlisted"], "description": "Describes the PRIMARY issuer. Drives which path scores company_relevance (Part A/B of the score breakdown)." },
    "private_linkage_tags": {
      "type": "array",
      "description": "Evidenced links from a private/unlisted primary issuer to a public company. Non-empty means the private_unlisted_irrelevance_penalty does not apply at its full cap — a private company is never auto-zeroed just for being private.",
      "items": {
        "type": "string",
        "enum": [
          "acquisition_target_of_public_acquirer",
          "supplier_or_customer_of_public_company",
          "competitor_informative_to_public_company",
          "commodity_sector_bottleneck",
          "ai_datacenter_supply_chain",
          "plausible_future_private_secondary_opportunity"
        ]
      }
    },
    "private_linkage_evidence": { "type": "string", "description": "One sentence naming the linked public company and how (e.g. a supplier-concentration disclosure)." },
    "linked_public_companies": { "type": "array", "items": { "type": "string" } },
    "routing": { "type": "string", "enum": ["PROMOTE", "PARK", "LOG", "watchlist_no_source", "suppress"] },
    "routing_reason": { "type": "string" },
    "next_action": { "type": "string" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_name", "retrieved_at", "claim_supported"],
        "properties": {
          "url": { "type": "string" },
          "source_name": { "type": "string" },
          "source_grade": { "type": "string", "enum": ["A", "B"] },
          "retrieved_at": { "type": "string" },
          "claim_supported": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "score_component": {
      "type": "object",
      "required": ["value", "max_value", "reason"],
      "properties": {
        "value": { "type": "integer", "minimum": 0 },
        "max_value": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string" }
      }
    },
    "score_penalty": {
      "type": "object",
      "required": ["value", "max_value", "reason"],
      "properties": {
        "value": { "type": "integer", "maximum": 0 },
        "max_value": { "type": "integer", "maximum": 0 },
        "reason": { "type": "string" }
      }
    }
  }
}
