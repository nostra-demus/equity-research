{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "frameworks/screener/candidates.schema.json",
  "title": "Candidate shortlist",
  "description": "The candidate-surfacing module's structured output: listed companies that express the locked thesis. Written to screener/runs/<SIG_ID>/candidates.json and copied to screener/ledger/candidates/<thesis_id>.json. This is the FIRST artifact in the pipeline allowed to contain tickers.",
  "type": "object",
  "required": ["thesis_id", "signal_id", "generated_at", "routing", "candidates"],
  "properties": {
    "thesis_id": { "type": "string" },
    "signal_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "routing": { "type": "string", "enum": ["provisional", "full_machine"] },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["candidate_id", "ticker", "company_name", "exchange", "side", "beneficiary_ref", "exposure_score", "exposure_rationale"],
        "properties": {
          "candidate_id": { "type": "string", "pattern": "^CND-[0-9]{3}$" },
          "ticker": { "type": "string" },
          "company_name": { "type": "string" },
          "exchange": { "type": "string" },
          "side": { "type": "string", "enum": ["long", "short", "pair_long_leg", "pair_short_leg"] },
          "beneficiary_ref": { "type": "string", "description": "The M0_3 party id this candidate expresses (e.g. DIR-001)." },
          "exposure_score": { "type": "integer", "minimum": 0, "maximum": 100, "description": "How purely this company expresses the thesis (revenue/EBITDA share tied to the affected industry, quantified where possible)." },
          "exposure_rationale": { "type": "string" },
          "liquidity_note": { "type": "string" },
          "prior_coverage": {
            "type": "object",
            "properties": {
              "has_run": { "type": "boolean", "description": "An analyses/<TICKER>_* run exists." },
              "latest_run_root": { "type": ["string", "null"] },
              "latest_decision": { "type": ["string", "null"] },
              "data_pool_present": { "type": "boolean", "description": "data/<TICKER>/ exists with files." }
            }
          },
          "pair_with": { "type": ["string", "null"], "description": "candidate_id of the other leg, for pair expressions." },
          "caveats": { "type": "string" },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source_name", "retrieved_at", "claim_supported"],
              "properties": {
                "url": { "type": "string" },
                "source_name": { "type": "string" },
                "source_grade": { "type": "string", "enum": ["A", "B"] },
                "retrieved_at": { "type": "string" },
                "claim_supported": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "handoff_status": {
      "type": "object",
      "description": "Filled/updated by /screener:handoff — which candidates were sent to the research swarm.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "handoff_id": { "type": "string" },
          "handed_off_at": { "type": "string" },
          "seeded_path": { "type": "string" }
        }
      }
    }
  }
}
