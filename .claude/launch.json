{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "cockpit-server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "ui/server", "run", "dev"],
      "port": 8787,
      "autoPort": true
    },
    {
      "name": "cockpit-dev-8899",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-lc", "cd ui/server && PORT=8899 GROQ_API_KEY= npx tsx src/server.ts"],
      "port": 8899
    },
    {
      "name": "cockpit-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "ui/web", "run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "cockpit-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "ui/web", "run", "preview", "--", "--port", "4173", "--strictPort"],
      "port": 4173
    },
    {
      "name": "dossier-site",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "site", "run", "dev"],
      "port": 4321
    }
  ]
}
